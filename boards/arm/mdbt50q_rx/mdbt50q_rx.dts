/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include "mdbt50q_rx-pinctrl.dtsi"

/ {
	model = "RAYTAC MDBT50Q-RX";
	compatible = "raytac,mdbt50q-rx";

	chosen {
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,uart-mcumgr = &uart0;
		zephyr,code-partition = &code_partition;
	};

	leds {
		compatible = "gpio-leds";
		led0: led_0 {
			gpios = <&gpio0 23 GPIO_ACTIVE_HIGH>;
			label = "Red LED";
		};
	};

	buttons {
		compatible = "gpio-keys";
		button0: button_0 {
			gpios = <&gpio0 18 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Push button switch";
		};
	};

	aliases {
		led0 = &led0;
		led1 = &led0;
		sw0 = &button0;
	};
};

&gpiote {
	status = "okay";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&uart0 {
	compatible = "nordic,nrf-uart";
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-1 = <&uart0_sleep>;
	pinctrl-names = "default", "sleep";
};

&i2c0 {
	compatible = "nordic,nrf-twim";
	status = "disabled";
	pinctrl-0 = <&i2c0_default>;
	pinctrl-1 = <&i2c0_sleep>;
	pinctrl-names = "default", "sleep";
};

&spi0 {
	compatible = "nordic,nrf-spim";
	status = "disabled";
	pinctrl-0 = <&spi0_default>;
	pinctrl-1 = <&spi0_sleep>;
	pinctrl-names = "default", "sleep";
};

&spi1 {
	compatible = "nordic,nrf-spim";
	status = "disabled";
	pinctrl-0 = <&spi1_default>;
	pinctrl-1 = <&spi1_sleep>;
	pinctrl-names = "default", "sleep";
};

&qspi {
	status = "disabled";
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* Adafruit Bootloader: 0x00000000 - 0x0000FFFF (64 KB) */
		bootloader_partition: partition@0 {
			label = "adafruit_bootloader";
			reg = <0x00000000 0x00010000>;
		};

		/* nRF52840 SoftDevice S140 v7.x: 0x00010000 - 0x00026FFF (92 KB) */
		sd_partition: partition@10000 {
			label = "softdevice";
			reg = <0x00010000 0x00017000>;
		};

		/* ZMK Application Code: 0x00027000 - 0x000FF000 (832 KB) */
		code_partition: partition@27000 {
			label = "code_partition";
			reg = <0x00027000 0x000D9000>;
		};

		/* Storage for ZMK settings: 0x000FF000 - 0x000FFFFF (4 KB) */
		storage_partition: partition@ff000 {
			label = "storage";
			reg = <0x000FF000 0x00001000>;
		};
	};
};
